# Copy this file to .env and fill in your testnet credentials.
# Never commit the real .env to version control.
#
# Get these from: https://testnet.binancefuture.com
# (Log in → Generate HMAC_SHA256 Key)

BINANCE_API_KEY=your_testnet_api_key_here

# Either name is accepted:
BINANCE_API_SECRET=your_testnet_api_secret_here
# BINANCE_SECRET_KEY=your_testnet_api_secret_here
